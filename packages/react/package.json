{
  "name": "@feedlog-ai/react",
  "version": "0.1.0",
  "description": "React bindings for Feedlog Toolkit Web Components",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "require": "./dist/next.js",
      "types": "./dist/next.d.ts"
    },
    "./ssr-components": {
      "import": "./dist/ssr-components.js",
      "require": "./dist/ssr-components.js",
      "types": "./dist/ssr-components.d.ts"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "require": "./dist/vite.js",
      "types": "./dist/vite.d.ts"
    },
    "./start": {
      "import": "./dist/start.js",
      "require": "./dist/start.js",
      "types": "./dist/start.d.ts"
    }
  },
  "files": [
    "dist",
    "BUILD_FEEDLOG_CLIENT.md",
    "BUILD_FEEDLOG_COMPOSABLE.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@feedlog-ai/webcomponents": "^0.1.0"
  },
  "devDependencies": {
    "@jest/test-sequencer": "^29.7.0",
    "next": "^15.5.15",
    "@stencil/ssr": "^0.3.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.24",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "6.4.2",
    "webpack": "^5.97.1"
  },
  "keywords": [
    "feedlog",
    "react",
    "components",
    "data-visualization"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/FeedlogAI/feedlog-toolkit",
    "directory": "packages/react"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
