{
  "name": "@feedlog-ai/vue",
  "version": "0.1.0",
  "description": "Vue bindings for Feedlog Toolkit Web Components",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "BUILD_FEEDLOG_CLIENT.md",
    "BUILD_FEEDLOG_COMPOSABLE.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@feedlog-ai/webcomponents": "^0.1.0"
  },
  "devDependencies": {
    "@jest/test-sequencer": "^30.3.0",
    "@testing-library/vue": "^8.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@vue/test-utils": "^2.4.3",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "vue": "^3.4.15"
  },
  "keywords": [
    "feedlog",
    "vue",
    "components",
    "data-visualization"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/FeedlogAI/feedlog-toolkit",
    "directory": "packages/vue"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
