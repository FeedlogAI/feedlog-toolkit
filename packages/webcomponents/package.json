{
  "name": "@feedlog-ai/webcomponents",
  "version": "0.2.2",
  "description": "Stencil web components for Feedlog Toolkit - Data visualization components",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "collection": "./dist/collection/collection-manifest.json",
  "unpkg": "./dist/feedlog-toolkit/feedlog-toolkit.esm.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/types/index.d.ts"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs.js",
      "types": "./loader/index.d.ts"
    },
    "./custom-elements": {
      "import": "./dist/components/index.js",
      "types": "./dist/types/components.d.ts"
    },
    "./components/*": {
      "import": "./dist/components/*.js",
      "types": "./dist/types/components/*.d.ts"
    },
    "./dist/components/*": {
      "import": "./dist/components/*.js",
      "types": "./dist/types/components/*.d.ts"
    },
    "./hydrate": {
      "types": "./hydrate/index.d.ts",
      "import": "./hydrate/index.mjs",
      "require": "./hydrate/index.js",
      "default": "./hydrate/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "custom-elements": [
        "./dist/types/components.d.ts"
      ],
      "loader": [
        "./loader/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "loader",
    "hydrate",
    "BUILD_FEEDLOG_CLIENT.md",
    "BUILD_FEEDLOG_COMPOSABLE.md"
  ],
  "sideEffects": [
    "dist/components/*.js"
  ],
  "scripts": {
    "build": "stencil build",
    "prepack": "npm run build",
    "start": "stencil build --dev --watch --serve",
    "dev": "stencil build --dev --watch --serve",
    "generate": "stencil generate",
    "test": "stencil test --spec",
    "test:watch": "stencil test --spec --watch",
    "test:coverage": "echo 'Webcomponents coverage skipped due to rollup issues'",
    "storybook": "storybook dev -p 6010 --no-open",
    "build-storybook": "storybook build",
    "clean": "rm -rf dist loader"
  },
  "dependencies": {
    "@feedlog-ai/core": "^0.2.2",
    "isomorphic-dompurify": "^2.16.0",
    "marked": "~17.0.2"
  },
  "devDependencies": {
    "@stencil/core": "^4.43.4",
    "@stencil/react-output-target": "^1.5.2",
    "@stencil/storybook-plugin": "^0.6.1",
    "@stencil/vue-output-target": "^0.13.1",
    "@types/node": "^25.6.0",
    "rollup": "^4.60.2",
    "storybook": "^10.3.6",
    "typescript": "^6.0.3",
    "vite": "6.4.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FeedlogAI/feedlog-toolkit",
    "directory": "packages/webcomponents"
  },
  "license": "MIT",
  "keywords": [
    "feedlog",
    "webcomponents",
    "stencil",
    "data-visualization"
  ],
  "publishConfig": {
    "access": "public"
  }
}
