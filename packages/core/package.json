{
  "name": "@feedlog-ai/core",
  "version": "0.0.50",
  "description": "Core SDK for Feedlog Toolkit",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ssr-globals": {
      "import": "./dist/utils/ssr-globals.js",
      "require": "./dist/utils/ssr-globals.js",
      "types": "./dist/utils/ssr-globals.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "BUILD_FEEDLOG_SDK_ONLY.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "feedlog",
    "sdk",
    "core"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "isomorphic-dompurify": "^2.16.0"
  },
  "devDependencies": {
    "@jest/test-sequencer": "^29.7.0",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^29.5.11",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.11.24",
    "dompurify": "^3.2.6",
    "jsdom": "^25.0.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
