{
  "name": "@feedlog-ai/core",
  "version": "0.1.0",
  "description": "Core SDK for Feedlog Toolkit",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ssr-globals": {
      "import": "./dist/utils/ssr-globals.js",
      "require": "./dist/utils/ssr-globals.js",
      "types": "./dist/utils/ssr-globals.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "BUILD_FEEDLOG_SDK_ONLY.md"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "feedlog",
    "sdk",
    "core"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/FeedlogAI/feedlog-toolkit",
    "directory": "packages/core"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "isomorphic-dompurify": "^2.16.0"
  },
  "devDependencies": {
    "@jest/test-sequencer": "^30.3.0",
    "@types/dompurify": "^3.2.0",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.6.0",
    "dompurify": "^3.4.1",
    "jsdom": "^29.0.2",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
