{
  "name": "feedlog-toolkit",
  "description": "Monorepo for Feedlog Toolkit - Core SDK, Web Components, and Framework Wrappers",
  "private": true,
  "overrides": {
    "@stencil/ssr": {
      "vite": "6.4.2"
    },
    "vite": "6.4.2"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:webcomponents && npm run build:react && npm run build:vue && npm run format && npm run verify:pack",
    "build:core": "npm run build --workspace=@feedlog-ai/core",
    "build:webcomponents": "npm run build --workspace=@feedlog-ai/webcomponents",
    "build:react": "npm run build --workspace=@feedlog-ai/react",
    "build:vue": "npm run build --workspace=@feedlog-ai/vue",
    "test": "npm run test --workspaces --if-present",
    "test:core": "npm run test --workspace=@feedlog-ai/core",
    "test:webcomponents": "npm run test --workspace=@feedlog-ai/webcomponents",
    "test:react": "npm run test --workspace=@feedlog-ai/react",
    "test:vue": "npm run test --workspace=@feedlog-ai/vue",
    "test:coverage": "npm run test:coverage --workspaces",
    "dev": "npm run dev --workspace=@feedlog-ai/webcomponents",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "storybook": "npm run storybook --workspace=@feedlog-ai/webcomponents",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish",
    "publish": "node scripts/publish-deprecated.mjs",
    "publish-patch": "node scripts/publish-deprecated.mjs",
    "publish-minor": "node scripts/publish-deprecated.mjs",
    "publish-major": "node scripts/publish-deprecated.mjs",
    "e2e": "npm run build && npm run build:examples && npx playwright install chromium && playwright test",
    "build:examples": "npm run build --workspace=react-ssr-example && npm run build --workspace=vue-ssr-example",
    "verify:pack": "node scripts/verify-pack.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@jest/test-sequencer": "^29.7.0",
    "@playwright/test": "^1.58.2",
    "@stencil/eslint-plugin": "^1.1.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-stencil": "^0.0.1",
    "eslint-plugin-storybook": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "storybook": "^9.1.17",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "6.4.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "optionalDependencies": {
    "@oxc-minify/binding-linux-arm64-gnu": "0.117.0",
    "@oxc-minify/binding-linux-x64-gnu": "0.117.0",
    "@oxc-parser/binding-linux-arm64-gnu": "0.117.0",
    "@oxc-parser/binding-linux-x64-gnu": "0.117.0",
    "@oxc-transform/binding-linux-arm64-gnu": "0.124.0",
    "@oxc-transform/binding-linux-x64-gnu": "0.117.0"
  }
}
